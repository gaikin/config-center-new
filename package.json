{
  "name": "config-center-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "dev:jssdk": "vite --config packages/jssdk/vite.config.ts",
    "build:jssdk": "tsc -p packages/jssdk/tsconfig.json && vite build --config packages/jssdk/vite.config.ts",
    "check:jssdk-demo": "tsc -p packages/jssdk/tsconfig.demo.json --noEmit",
    "backend:dev": "mvn -f backend/pom.xml spring-boot:run",
    "backend:build": "mvn -f backend/pom.xml -DskipTests package",
    "backend:start": "java -jar backend/target/config-center-backend-0.1.0.jar"
  },
  "dependencies": {
    "@lexical/react": "^0.41.0",
    "@lexical/rich-text": "^0.41.0",
    "@lexical/selection": "^0.41.0",
    "@xyflow/react": "^12.10.1",
    "antd": "^5.27.2",
    "lexical": "^0.41.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-querybuilder": "^8.14.0",
    "react-router-dom": "^6.30.1",
    "styled-components": "^6.1.18",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/styled-components": "^5.1.34",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.52.4"
  }
}
